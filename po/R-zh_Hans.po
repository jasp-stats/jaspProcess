msgstr "总计"

msgid "Total indirect"
msgstr "总间接效应"

msgid "Local tests"
msgstr "局部检验"

msgid "Conditional independence tests"
msgstr "条件独立性检验"

msgid "Model did not converge."
msgstr "模型未收敛。"

msgid "RMSEA"
msgstr "近似误差均方根 （RMSEA）"

