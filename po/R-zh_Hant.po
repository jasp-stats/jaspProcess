msgstr "百分位"

msgid "normal theory"
msgstr "常態理論"

msgid "Moderated mediation index"
msgstr "調節式中介指標"

msgid "Total"
msgstr "總計"

msgid "Total indirect"
msgstr "總間接效果"

msgid "Local tests"
msgstr "局部檢定"

msgid "Conditional independence tests"
msgstr "條件獨立性檢定"

msgid "Model did not converge."
msgstr "模型未收斂。"

msgid "RMSEA"
msgstr ""

